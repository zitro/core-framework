# Provider Selection: "azure" | "openai" | "local"
LLM_PROVIDER=local
STORAGE_PROVIDER=local
AUTH_PROVIDER=none
SPEECH_PROVIDER=none

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (direct)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Cosmos DB
# COSMOS_ENDPOINT=
# COSMOS_KEY=
# COSMOS_DATABASE=core-discovery

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=core-discovery

# Azure Speech
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# Azure Entra ID
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Microsoft Graph (read-only). Reuses AZURE_TENANT_ID / CLIENT_ID / SECRET.
# GRAPH_PROVIDER=msgraph

# Dynamics 365 / Dataverse (read-only). Reuses AZURE_* credentials.
# DYNAMICS_PROVIDER=dataverse
# DYNAMICS_URL=https://<org>.crm.dynamics.com

# CORS
CORS_ORIGINS=["http://localhost:3000"]
