# Provider Selection: "azure" | "openai" | "local"
LLM_PROVIDER=local
STORAGE_PROVIDER=local
AUTH_PROVIDER=none
SPEECH_PROVIDER=none

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (direct)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# OpenAI-compatible transcription (SPEECH_PROVIDER=openai)
# OPENAI_TRANSCRIPTION_API_KEY=        # optional; falls back to OPENAI_API_KEY
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# OPENAI_TRANSCRIPTION_BASE_URL=       # optional; falls back to OPENAI_BASE_URL

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Cosmos DB
# COSMOS_ENDPOINT=
# COSMOS_KEY=
# COSMOS_DATABASE=core-discovery
# When true, FastAPI startup will create missing Cosmos containers. Set during
# initial provisioning or in dev; leave off in steady-state production.
# COSMOS_ENSURE_COLLECTIONS=false

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=core-discovery

# Azure Speech (SPEECH_PROVIDER=azure)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
# AZURE_SPEECH_RESOURCE_ID=

# Azure Entra ID
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# In production prefer Managed Identity / Workload Identity (no AZURE_CLIENT_SECRET in env)
# and source secrets from Azure Key Vault. Graph and Dataverse providers will fall back to
# DefaultAzureCredential when AZURE_CLIENT_SECRET is unset.

# Microsoft Graph (read-only). Reuses AZURE_TENANT_ID / CLIENT_ID / SECRET.
# GRAPH_PROVIDER=msgraph

# Dynamics 365 / Dataverse (read-only). Reuses AZURE_* credentials.
# DYNAMICS_PROVIDER=dataverse
# DYNAMICS_URL=https://<org>.crm.dynamics.com

# GitHub OAuth (optional, for private repo attach via UI)
# Keep values local only and never commit them.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/github/oauth/callback
# GITHUB_OAUTH_SCOPE=read:user repo
# SECRET_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
